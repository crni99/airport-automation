<nav aria-label="Page navigation">
    <ul class="pagination pagination-container pagination-container-absolute">
        <li class="page-item">
            <a href="@Url.Action("Edit", new { id=Model.Id })" class="page-link text-success">Edit</a>
        </li>
        <li class="page-item">
            <form method="post" action="@Url.Action("Delete", new { id = Model.Id })"
                  onsubmit="return confirm('Are you sure you want to delete this item?')">
                @Html.AntiForgeryToken()
                <button type="submit" class="page-link text-danger" style="background:none; border:none;">
                    Delete
                </button>
            </form>
        </li>
        <li class="page-item">
            <a asp-action="Index" class="page-link">Back to List</a>
        </li>
    </ul>
</nav>